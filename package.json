{
  "name": "pocketvideo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r --no-cache test && vp run -r --no-cache build",
    "dev": "vp run --no-cache @pocketvideo/demo#dev",
    "render:image": "bun tools/render-skia/src/cli.ts image",
    "render:video": "bun tools/render-skia/src/cli.ts video",
    "test": "vp run -r --no-cache test",
    "build": "vp run -r --no-cache build",
    "check": "vp check"
  },
  "devDependencies": {
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "0.2.5"
  },
  "trustedDependencies": [
    "skia-canvas"
  ]
}
